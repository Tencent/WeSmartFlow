# 复制此文件到仓库根目录的 .env 并填入真实值（注意：.env 放在仓库根，不在 backend/ 下）
# cp backend/.env.example .env

# ============================================================
# LLM 配置（OpenAI 兼容协议）
# ============================================================

LLM_API_KEY=""          # sk-your-key-here
LLM_BASE_URL=""         # https://api.openai.com/v1
LLM_MODEL=""            # gpt-4o
# PROFILE_LLM_MODEL=""  # 可选：画像提取/编译专用模型，建议 deepseek-chat 等 tool_call 稳定模型

# ============================================================
# 图像生成（OpenAI 兼容协议）
# ============================================================

IMG_API_KEY=""          # sk-your-key-here
IMG_MODEL=""            # gpt-image-1
IMG_BASE_URL=""         # https://api.openai.com/v1

# ============================================================
# 通用配置
# ============================================================

# Tavily 搜索
TAVILY_API_KEY=""       # tvly-xxx

# 服务配置（可选，有默认值）
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:5173

# JWT 密钥（生产环境必须改成长随机串）
JWT_SECRET="change-me-in-production"
JWT_EXPIRE_HOURS=72

# 免费额度配置（每用户总量，用完即止）
FREE_LLM_TOTAL=100       # LLM 调用总次数
FREE_SEARCH_TOTAL=30     # 搜索总次数
FREE_IMAGE_TOTAL=15      # 图片生成总次数

# ============================================================
# 认证配置（至少配置一种登录方式）
# ============================================================

# SMTP 邮件配置（邮箱验证码登录）
SMTP_HOST=""            # smtp.qq.com
SMTP_PORT=465
SMTP_USER=""            # 发件邮箱
SMTP_PASSWORD=""        # SMTP 授权码
SMTP_FROM_NAME="WeSmartFlow"

# 微信小程序配置（扫码登录）
WECHAT_MP_APPID=""
WECHAT_MP_SECRET=""

# GitHub OAuth 配置
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================================
# 内容安全审核（可选，体验站建议开启）
# ============================================================

CONTENT_GUARD_ENABLED=false                  # 是否启用内容审核（true/false）
CONTENT_GUARD_LLM_ENABLED=true               # 是否启用 LLM 语义审核（默认 true，需先启用上面的开关）
# CONTENT_RULES_PATH=config/content_rules.yaml   # 规则文件路径
# CONTENT_GUARD_LLM_MODEL=                       # 语义审核用的模型（默认用 LLM_MODEL，建议用轻量模型）

# ============================================================
# 知识图谱（KG，内嵌运行，基于 sqlite-vec）
# ============================================================

# 数据目录（默认仓库根 ./data）
# KG_DATA_DIR=
# KG_DB_FILE=kg.db

# 向量库（sqlite-vec，单文件，多进程友好；无需独立服务）
# KG_VEC_DB_FILE=kg_vec.db
# KG_VEC_DB_PATH=         # 留空则使用 KG_DATA_DIR/KG_VEC_DB_FILE

# Embedding（强烈建议配置；不配则 KG 退化为纯 FTS，召回效果大幅下降）
KG_EMBEDDING_API_KEY=""
KG_EMBEDDING_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
KG_EMBEDDING_MODEL="text-embedding-v4"
KG_EMBEDDING_DIM=1024
KG_EMBEDDING_BATCH=10
