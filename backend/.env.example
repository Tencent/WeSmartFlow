# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ============================================================
# LLM 配置（OpenAI 兼容协议）
# ============================================================

LLM_API_KEY=""          # sk-your-key-here
LLM_BASE_URL=""         # https://api.openai.com/v1
LLM_MODEL=""            # gpt-4o

# ============================================================
# 图像生成（OpenAI 兼容协议）
# ============================================================

IMG_API_KEY=""          # sk-your-key-here
IMG_MODEL=""            # gpt-image-1
IMG_BASE_URL=""         # https://api.openai.com/v1

# ============================================================
# 通用配置
# ============================================================

# Tavily 搜索
TAVILY_API_KEY=""       # tvly-xxx

# 服务配置（可选，有默认值）
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:5173

# 免费额度配置（每用户总量，用完即止）
FREE_LLM_TOTAL=100       # LLM 调用总次数
FREE_SEARCH_TOTAL=30      # 搜索总次数
FREE_IMAGE_TOTAL=15       # 图片生成总次数

# ============================================================
# 认证配置（至少配置一种登录方式）
# ============================================================

# SMTP 邮件配置（邮箱验证码登录）
SMTP_HOST=""            # smtp.qq.com
SMTP_PORT=465
SMTP_USER=""            # 发件邮箱
SMTP_PASSWORD=""        # SMTP 授权码
SMTP_FROM_NAME="WeSmartFlow"

# 微信小程序配置（扫码登录）
WECHAT_MP_APPID=""
WECHAT_MP_SECRET=""

# GitHub OAuth 配置
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================================
# 内容安全审核（可选，体验站建议开启）
# ============================================================

CONTENT_GUARD_ENABLED=false                  # 是否启用内容审核（true/false）
# CONTENT_RULES_PATH=""                      # 规则文件路径（默认 config/content_rules.yaml）
CONTENT_GUARD_LLM_ENABLED=true               # 是否启用 LLM 语义审核（默认 true，需先启用上面的开关）
# CONTENT_GUARD_LLM_MODEL=""                 # 语义审核用的模型（默认用 LLM_MODEL，建议用轻量模型如 gpt-4o-mini）
