# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# LLM 配置（必填）
OPENAI_API_KEY=""  # sk-your-key-here
OPENAI_BASE_URL=""  # https://api.openai.com/v1
LLM_MODEL=""  # gpt-4o

# 服务配置（可选，有默认值）
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:5173


# 图像模型 aip
IMG_API_KEY=""  # sk-your-key-here
IMG_MODEL=""  # your-model
IMG_BASE_URL=""  # your-base-url

# tavily
TAVILY_API_KEY=""  # sk-your-key-here

# 免费额度配置（每用户总量，用完即止）
FREE_LLM_TOTAL=100       # LLM 调用总次数
FREE_SEARCH_TOTAL=30      # 搜索总次数
FREE_IMAGE_TOTAL=15       # 图片生成总次数
